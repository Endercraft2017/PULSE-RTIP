{
  "name": "pulse-rtip",
  "version": "0.1.0",
  "description": "PULSE: Real-Time Incident Reporting Platform for MDRRMO Morong, Rizal",
  "main": "electron/main.js",
  "scripts": {
    "dev:web": "npx serve src/frontend --listen 3000 --no-clipboard",
    "dev:electron": "electron .",
    "build:win": "electron-builder --win",
    "start": "electron .",
    "cap:sync": "npx cap sync android",
    "cap:build": "set GRADLE_USER_HOME=d:/gradle-home && npx cap sync android && cd android && gradlew assembleDebug",
    "cap:open": "npx cap open android"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Endercraft2017/PULSE-RTIP.git"
  },
  "author": "PULSE-RTIP Team",
  "license": "UNLICENSED",
  "private": true,
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "serve": "^14.0.0"
  },
  "build": {
    "appId": "com.mdrrmo.pulse-rtip",
    "productName": "PULSE 911",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "src/frontend/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0"
  }
}
